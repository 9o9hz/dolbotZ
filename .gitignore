# Python cache
__pycache__/
*.pyc
*.egg-info/

# Python virtual environment
.venv/

# ROS2 / colcon
build/
install/
log/

# VSCode
.vscode/

# ultralytics 학습 산출물 — 검증된 가중치만 의도적으로 config/models/로
# 수동 복사한다 (config/models/README.md 참고). 재현 가능한 산출물이라
# git으로 추적하지 않는다.
runs/

# 사전학습 베이스 가중치 — ultralytics가 YOLO("yolo26n-seg.pt") 최초 실행 시
# 자동 다운로드하므로 git에 포함하지 않는다. train_drive_area.py 상단 주석 참고.
yolo26n-seg.pt

# API 키/시크릿 — ROBOFLOW_API_KEY 등은 환경변수로만 전달한다 (train_drive_area.py
# 참고). 나중에 로컬 파일로 관리하게 될 경우를 대비한 방어적 규칙.
.env
*.key
secrets/
